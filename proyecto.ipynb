    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "sns.histplot(\n",
    "    data = df1_copia,\n",
    "    x = 'pCut::Motor_Torque',\n",
    "    hue = 'mode',\n",
    "    kde = True,\n",
    "    stat = 'density',\n",
    "    common_norm = False,\n",
    "    alpha = 0.5,\n",
    "    ax = ax,\n",
    "    bins = 10\n",
    ")\n",
    "ax.set_title('Distribución de la fuerza del motor en la estación de corte por modo')\n",
    "ax.set_xlabel('Fuerza del motor en la estación de corte')\n",
    "ax.set_ylabel('Densidad')\n",
    "plt.tight_layout()\n",
    "plt.show()"
